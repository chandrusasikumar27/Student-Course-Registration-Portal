<!DOCTYPE html>
<html>
<head>
    <title>Student Registration</title>
    <link rel="stylesheet" href="training institute.css">
</head>
<body>

<h2>ABC Training Institute</h2>

<form id="f">

Name:<br>
<input type="text" id="n"><br><br>

Email:<br>
<input type="email" id="e"><br><br>

Mobile:<br>
<input type="text" id="m"><br><br>

Gender:
<input type="radio" name="g">Male
<input type="radio" name="g">Female
<br><br>

Department:<br>
<input type="text" id="d"><br><br>

Course:<br>
<select id="c">
<option>Java</option>
<option>Python</option>
<option>AI</option>
</select><br><br>

DOB:<br>
<input type="date" id="dob"><br><br>

<input type="submit">
<input type="reset">

</form>

<h3>Registered Students</h3>

<table border="1" id="t">
<tr>
<th>Name</th>
<th>Course</th>
<th>Department</th>
</tr>
</table>

<script src="script.js"></script>

</body>
</html>
