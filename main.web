body{
font-family:Arial;
background:#eef5ff;
text-align:center;
}

form{
width:300px;
margin:auto;
padding:20px;
background:white;
border-radius:10px;
box-shadow:0 0 10px gray;
}

input,select{
width:90%;
padding:8px;
margin:6px;
border-radius:5px;
}

input:hover,select:hover{
background:#d9f0ff;
}

input[type=submit],
input[type=reset]{
background:blue;
color:white;
}

table{
margin:auto;
margin-top:20px;
border-collapse:collapse;
width:70%;
}

th{
background:blue;
color:white;
}

th,td{
padding:8px;
}
